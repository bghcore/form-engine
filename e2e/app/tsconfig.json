{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": false,
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@formosaic/core": ["../../packages/core/src"],
      "@formosaic/fluent": ["../../packages/fluent/src"]
    }
  },
  "include": ["src/**/*"]
}
